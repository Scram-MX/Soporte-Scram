# ===========================================
# Variables de Entorno para Docker - GLPI Helpdesk
# ===========================================
# IMPORTANTE: Configura estos valores antes de ejecutar docker-compose
# Este archivo NO debe subirse al repositorio con valores reales

# ===========================================
# GLPI API Configuration (Frontend)
# ===========================================
VITE_GLPI_URL=https://glpi.scram2k.com
VITE_GLPI_APP_TOKEN=
VITE_GLPI_USER_TOKEN=

# ===========================================
# Gemini AI Configuration (Asistente IA)
# ===========================================
# Obtener API key en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash-latest

# ===========================================
# Smartsheet Sync Configuration
# ===========================================
SMARTSHEET_TOKEN=
SMARTSHEET_SHEET_ID=

# ===========================================
# GLPI Backend Configuration (para sync)
# ===========================================
GLPI_URL=https://glpi.scram2k.com/apirest.php
GLPI_APP_TOKEN=
GLPI_USERNAME=
GLPI_PASSWORD=

# ===========================================
# Sync Interval (minutos)
# ===========================================
SYNC_INTERVAL=5

# ===========================================
# Timezone
# ===========================================
TZ=America/Mexico_City
